page {
  background-color: #FFF5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.container {
  padding: 20rpx;
}

.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-around {
  justify-content: space-around;
}

.align-center {
  align-items: center;
}

.flex-1 {
  flex: 1;
}

.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.text-primary {
  color: #FF6B6B;
}

.text-secondary {
  color: #4ECDC4;
}

.text-warning {
  color: #FFEAA7;
}

.text-info {
  color: #45B7D1;
}

.text-success {
  color: #96CEB4;
}

.text-danger {
  color: #FF6B6B;
}

.text-muted {
  color: #999999;
}

.text-light {
  color: #CCCCCC;
}

.bg-primary {
  background-color: #FF6B6B;
}

.bg-secondary {
  background-color: #4ECDC4;
}

.bg-warning {
  background-color: #FFEAA7;
}

.bg-info {
  background-color: #45B7D1;
}

.bg-success {
  background-color: #96CEB4;
}

.bg-danger {
  background-color: #FF6B6B;
}

.bg-white {
  background-color: #FFFFFF;
}

.bg-light {
  background-color: #FFF5F5;
}

.border-radius {
  border-radius: 16rpx;
}

.border-radius-sm {
  border-radius: 8rpx;
}

.border-radius-lg {
  border-radius: 24rpx;
}

.shadow {
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.shadow-sm {
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.shadow-lg {
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.12);
}

.mt-10 {
  margin-top: 10rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mt-30 {
  margin-top: 30rpx;
}

.mt-40 {
  margin-top: 40rpx;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.mb-30 {
  margin-bottom: 30rpx;
}

.mb-40 {
  margin-bottom: 40rpx;
}

.p-10 {
  padding: 10rpx;
}

.p-20 {
  padding: 20rpx;
}

.p-30 {
  padding: 30rpx;
}

.px-20 {
  padding-left: 20rpx;
  padding-right: 20rpx;
}

.px-30 {
  padding-left: 30rpx;
  padding-right: 30rpx;
}

.py-20 {
  padding-top: 20rpx;
  padding-bottom: 20rpx;
}

.py-30 {
  padding-top: 30rpx;
  padding-bottom: 30rpx;
}

.font-sm {
  font-size: 24rpx;
}

.font-base {
  font-size: 28rpx;
}

.font-lg {
  font-size: 32rpx;
}

.font-xl {
  font-size: 36rpx;
}

.font-xxl {
  font-size: 44rpx;
}

.font-bold {
  font-weight: bold;
}

.font-normal {
  font-weight: normal;
}

.line-clamp-1 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.line-clamp-3 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.4);
}

.btn-secondary {
  background: linear-gradient(135deg, #4ECDC4 0%, #6EE7DE 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(78, 205, 196, 0.4);
}

.btn-outline {
  background: #FFFFFF;
  color: #FF6B6B;
  border: 2rpx solid #FF6B6B;
  border-radius: 50rpx;
  padding: 18rpx 38rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-block {
  display: block;
  width: 100%;
  box-sizing: border-box;
}

.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-state text {
  color: #999999;
  font-size: 28rpx;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #EEEEEE, transparent);
  margin: 20rpx 0;
}

.badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  background: #FF6B6B;
}

.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.tag-primary {
  background: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
}

.tag-secondary {
  background: rgba(78, 205, 196, 0.1);
  color: #4ECDC4;
}

.tag-info {
  background: rgba(69, 183, 209, 0.1);
  color: #45B7D1;
}

.tag-success {
  background: rgba(150, 206, 180, 0.1);
  color: #96CEB4;
}

.avatar {
  border-radius: 50%;
  overflow: hidden;
}

.avatar-sm {
  width: 60rpx;
  height: 60rpx;
}

.avatar-md {
  width: 80rpx;
  height: 80rpx;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
}

.avatar-xl {
  width: 160rpx;
  height: 160rpx;
}
