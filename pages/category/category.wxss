.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFFFFF 100%);
}

.page-header {
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
}

.page-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.category-tabs {
  background: #FFFFFF;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tabs-list {
  padding: 0 20rpx;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  margin: 0 10rpx;
  border-radius: 20rpx;
  position: relative;
  flex-shrink: 0;
}

.tab-item.active {
  background: linear-gradient(135deg, #FF6B6B20 0%, #FF8E8E20 100%);
}

.tab-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.tab-name {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

.tab-item.active .tab-name {
  color: #FF6B6B;
}

.tab-count {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: #FF6B6B;
  color: #FFFFFF;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
}

.sort-bar {
  display: flex;
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.sort-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666666;
  position: relative;
}

.sort-item.active {
  color: #FF6B6B;
  font-weight: bold;
}

.sort-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 3rpx;
}

.content {
  flex: 1;
  padding: 20rpx;
}

.recipe-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.recipe-item {
  width: 48%;
  margin-bottom: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.recipe-image {
  width: 100%;
  height: 240rpx;
  position: relative;
  background: linear-gradient(135deg, #FFEAA7 0%, #FF6B6B 100%);
}

.recipe-image image {
  width: 100%;
  height: 100%;
}

.recipe-category {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.recipe-category text {
  font-size: 20rpx;
  color: #FFFFFF;
}

.recipe-info {
  padding: 16rpx;
}

.recipe-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}

.recipe-desc {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
  line-height: 1.4;
  display: block;
}

.recipe-stats {
  margin-top: 12rpx;
}

.recipe-stats .stat-item {
  display: flex;
  align-items: center;
  margin-right: 16rpx;
}

.recipe-stats .stat-item text:first-child {
  font-size: 20rpx;
  margin-right: 4rpx;
}

.recipe-stats .stat-item text:last-child {
  font-size: 20rpx;
  color: #999999;
}

.empty-state {
  padding: 120rpx 40rpx;
}

.loading-state,
.no-more {
  padding: 40rpx;
  text-align: center;
}
