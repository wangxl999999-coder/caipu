.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFFFFF 100%);
}

.content {
  flex: 1;
  padding-bottom: calc(env(safe-area-inset-bottom) + 100rpx);
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input {
  flex: 1;
  background: #FFFFFF;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  margin-right: 20rpx;
}

.search-icon {
  margin-right: 16rpx;
}

.search-icon text {
  font-size: 32rpx;
}

.search-input input {
  font-size: 28rpx;
  color: #333333;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  background: #EEEEEE;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-clear text {
  font-size: 24rpx;
  color: #999999;
}

.search-btn {
  padding: 16rpx 24rpx;
}

.search-btn text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
}

.section {
  padding: 0 30rpx;
  margin-top: 30rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
}

.title-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.section-more {
  display: flex;
  align-items: center;
}

.section-more text {
  font-size: 26rpx;
  color: #999999;
}

.section-more .arrow {
  font-size: 32rpx;
  margin-left: 8rpx;
}

.daily-scroll {
  white-space: nowrap;
}

.daily-list {
  display: inline-flex;
  padding-right: 30rpx;
}

.daily-item {
  width: 320rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.daily-item:last-child {
  margin-right: 0;
}

.daily-image {
  position: relative;
  width: 100%;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #FFEAA7 0%, #FF6B6B 100%);
}

.daily-image image {
  width: 100%;
  height: 100%;
}

.daily-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.9);
}

.daily-badge text {
  font-size: 22rpx;
  color: #FFFFFF;
}

.daily-info {
  padding-top: 16rpx;
}

.daily-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}

.daily-stats {
  margin-top: 10rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.stat-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.stat-num {
  font-size: 24rpx;
  color: #999999;
}

.daily-empty {
  width: 100%;
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  color: #999999;
  font-size: 26rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.category-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.category-icon text {
  font-size: 48rpx;
}

.category-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.category-count {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.recipe-list {
  margin-bottom: 30rpx;
}

.recipe-card {
  display: flex;
  overflow: hidden;
}

.recipe-image {
  width: 240rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  background: linear-gradient(135deg, #FFEAA7 0%, #FF6B6B 100%);
}

.recipe-image image {
  width: 100%;
  height: 100%;
}

.recipe-difficulty {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 12rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 20rpx;
}

.recipe-difficulty text {
  font-size: 20rpx;
  color: #FFFFFF;
}

.recipe-time {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
}

.recipe-time text {
  font-size: 20rpx;
  color: #FF6B6B;
}

.recipe-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.recipe-title {
  margin-bottom: 10rpx;
}

.recipe-title .title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
}

.recipe-category {
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.recipe-category text {
  font-size: 22rpx;
  color: #FFFFFF;
}

.recipe-desc {
  font-size: 24rpx;
  line-height: 1.5;
}

.recipe-footer {
  margin-top: 12rpx;
}

.recipe-author {
  flex-shrink: 0;
}

.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  background: #EEEEEE;
}

.author-name {
  font-size: 22rpx;
}

.recipe-stats {
  flex-shrink: 0;
}

.loading-state {
  padding: 40rpx;
  text-align: center;
}

.no-more {
  padding: 30rpx;
  text-align: center;
}
