.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 60rpx;
}

.header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 50%, #FFB3B3 100%);
  padding: 60rpx 30rpx 50rpx;
  text-align: center;
}

.logo-wrapper {
  margin-bottom: 20rpx;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.logo-icon {
  font-size: 72rpx;
}

.app-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
}

.version {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
  display: block;
}

.section {
  background: #FFFFFF;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.intro-box {
  background: linear-gradient(135deg, #FFF5F5 0%, #FFFFFF 100%);
  padding: 24rpx;
  border-radius: 16rpx;
  border-left: 6rpx solid #FF6B6B;
}

.intro-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}

.contact-list {
  
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.contact-icon text {
  font-size: 36rpx;
}

.contact-info {
  flex: 1;
}

.contact-label {
  font-size: 26rpx;
  color: #999999;
  display: block;
}

.contact-value {
  font-size: 28rpx;
  color: #333333;
  margin-top: 6rpx;
  display: block;
}

.contact-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  margin-left: 20rpx;
}

.menu-list {
  
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  font-size: 28rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
}

.footer {
  text-align: center;
  padding: 40rpx 30rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

.footer-desc {
  font-size: 22rpx;
  color: #CCCCCC;
  margin-top: 10rpx;
  display: block;
}
