.page {
  min-height: 100vh;
  background: #F5F5F5;
}

.user-header {
  position: relative;
  padding-bottom: 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  overflow: hidden;
}

.bg-gradient {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 50%, #FFB3B3 100%);
  border-radius: 0 0 60rpx 60rpx;
}

.user-info {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 80rpx 30rpx 30rpx;
}

.avatar-wrapper {
  position: relative;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid rgba(255, 255, 255, 0.8);
}

.avatar-placeholder text {
  font-size: 60rpx;
}

.info-content {
  flex: 1;
  margin-left: 24rpx;
}

.nickname {
  margin-bottom: 8rpx;
}

.nickname-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.vip-badge {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
}

.vip-badge text {
  font-size: 20rpx;
  color: #FFFFFF;
}

.user-id {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.logout-btn {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
}

.logout-btn text {
  font-size: 24rpx;
  color: #FFFFFF;
}

.login-prompt {
  cursor: pointer;
}

.login-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
}

.login-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
  display: block;
}

.login-arrow text {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.8);
}

.statistics {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #FFFFFF;
  margin: 0 30rpx;
  padding: 30rpx 0;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B6B;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  display: block;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #EEEEEE;
}

.content {
  padding: 30rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 100rpx);
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  background: #FFFFFF;
  padding: 30rpx;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
}

.action-icon text {
  font-size: 44rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666666;
}

.menu-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.menu-header {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  flex: 1;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon text {
  font-size: 32rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333333;
}

.menu-arrow text {
  font-size: 36rpx;
  color: #CCCCCC;
}
