<view class="page">
  <view class="page-header">
    <text class="page-title">我的发布</text>
    <text class="page-desc">共 {{total}} 道菜谱</text>
  </view>

  <view class="filter-bar">
    <view class="filter-item {{currentStatus == -1 ? 'active' : ''}}" bindtap="onStatusChange" data-status="-1">
      <text>全部</text>
    </view>
    <view class="filter-item {{currentStatus == 0 ? 'active' : ''}}" bindtap="onStatusChange" data-status="0">
      <text>待审核</text>
    </view>
    <view class="filter-item {{currentStatus == 1 ? 'active' : ''}}" bindtap="onStatusChange" data-status="1">
      <text>已发布</text>
    </view>
    <view class="filter-item {{currentStatus == 2 ? 'active' : ''}}" bindtap="onStatusChange" data-status="2">
      <text>已下架</text>
    </view>
  </view>

  <scroll-view class="content" scroll-y enhanced enablePullDownRefresh>
    <view class="recipe-list" wx:if="{{recipes.length > 0}}">
      <view 
        class="recipe-item card" 
        wx:for="{{recipes}}" 
        wx:key="id"
      >
        <view class="recipe-image" bindtap="goToRecipeDetail" data-id="{{item.id}}">
          <image src="{{item.image || '/static/images/default-recipe.png'}}" mode="aspectFill" lazy-load />
          <view class="recipe-status {{getStatusClass(item.status)}}">
            <text>{{getStatusText(item.status)}}</text>
          </view>
        </view>
        <view class="recipe-info">
          <text class="recipe-title line-clamp-1" bindtap="goToRecipeDetail" data-id="{{item.id}}">{{item.title}}</text>
          <view class="recipe-meta">
            <view class="meta-category" style="background: {{item.category_color}}20;">
              <text style="color: {{item.category_color}};">{{item.category_name}}</text>
            </view>
            <text class="meta-time text-muted">{{item.create_time}}</text>
          </view>
          <view class="recipe-footer flex justify-between align-center">
            <view class="recipe-stats flex">
              <view class="stat-item">
                <text>👁️</text>
                <text>{{item.view_count}}</text>
              </view>
              <view class="stat-item">
                <text>❤️</text>
                <text>{{item.like_count}}</text>
              </view>
              <view class="stat-item">
                <text>⭐</text>
                <text>{{item.favorite_count}}</text>
              </view>
            </view>
            <view class="action-btns">
              <view class="edit-btn" bindtap="goToEdit" data-id="{{item.id}}">
                <text>编辑</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{recipes.length === 0 && !loading}}">
      <image src="/static/images/empty-recipe.png" mode="aspectFit" />
      <text class="text-muted">暂无发布的菜谱~</text>
      <view class="empty-action" bindtap="goToPublish">
        <text>去发布菜谱</text>
      </view>
    </view>

    <view class="loading-state" wx:if="{{loading && recipes.length > 0}}">
      <text class="text-muted">加载中...</text>
    </view>

    <view class="no-more" wx:if="{{!hasMore && recipes.length > 0}}">
      <text class="text-muted">没有更多了~</text>
    </view>
  </scroll-view>
</view>
