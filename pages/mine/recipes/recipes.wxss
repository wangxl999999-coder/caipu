.page {
  min-height: 100vh;
  background: #F5F5F5;
}

.page-header {
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
}

.page-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.filter-bar {
  display: flex;
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666666;
  position: relative;
}

.filter-item.active {
  color: #FF6B6B;
  font-weight: bold;
}

.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 3rpx;
}

.content {
  height: calc(100vh - 260rpx);
  padding: 20rpx;
}

.recipe-list {
  padding-bottom: 30rpx;
}

.recipe-item {
  display: flex;
  overflow: hidden;
}

.recipe-image {
  width: 240rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  background: linear-gradient(135deg, #FFEAA7 0%, #FF6B6B 100%);
}

.recipe-image image {
  width: 100%;
  height: 100%;
}

.recipe-status {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.status-pending {
  background: rgba(255, 165, 0, 0.9);
}

.status-published {
  background: rgba(76, 175, 80, 0.9);
}

.status-offline {
  background: rgba(158, 158, 158, 0.9);
}

.recipe-status text {
  font-size: 20rpx;
  color: #FFFFFF;
}

.recipe-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.recipe-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}

.recipe-meta {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.meta-category {
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.meta-category text {
  font-size: 20rpx;
}

.meta-time {
  font-size: 22rpx;
}

.recipe-footer {
  margin-top: 12rpx;
}

.recipe-stats {
  flex-shrink: 0;
}

.stat-item {
  display: flex;
  align-items: center;
  margin-right: 16rpx;
}

.stat-item text:first-child {
  font-size: 20rpx;
  margin-right: 4rpx;
}

.stat-item text:last-child {
  font-size: 20rpx;
  color: #999999;
}

.action-btns {
  display: flex;
  align-items: center;
}

.edit-btn {
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, #4ECDC4 0%, #6EE7DE 100%);
  border-radius: 30rpx;
}

.edit-btn text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-action {
  margin-top: 30rpx;
  padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 50rpx;
  display: inline-block;
}

.empty-action text {
  font-size: 26rpx;
  color: #FFFFFF;
}

.loading-state,
.no-more {
  padding: 40rpx;
  text-align: center;
}
