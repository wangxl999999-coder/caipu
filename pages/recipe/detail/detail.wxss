.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 120rpx;
}

.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.recipe-container {
  padding-bottom: 30rpx;
}

.recipe-header {
  background: #FFFFFF;
}

.recipe-image {
  width: 100%;
  height: 500rpx;
  position: relative;
}

.recipe-image image {
  width: 100%;
  height: 100%;
}

.recipe-meta {
  padding: 30rpx;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.author-info {
  flex-shrink: 0;
}

.author-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #EEEEEE;
}

.author-name {
  font-size: 26rpx;
  color: #666666;
}

.recipe-category {
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
}

.recipe-category text {
  font-size: 24rpx;
  color: #FFFFFF;
}

.recipe-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.4;
  display: block;
}

.recipe-desc {
  font-size: 26rpx;
  color: #999999;
  line-height: 1.6;
  margin-top: 16rpx;
  display: block;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.tag {
  margin-right: 16rpx;
  margin-bottom: 12rpx;
}

.section {
  background: #FFFFFF;
  margin-top: 20rpx;
  padding: 30rpx;
}

.stats-section {
  padding: 20rpx 0;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
}

.stat-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.stat-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.title-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.materials-grid {
  display: flex;
  flex-wrap: wrap;
}

.material-item {
  width: 48%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFFFFF 100%);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.material-item:nth-child(odd) {
  margin-right: 4%;
}

.material-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.material-amount {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: bold;
}

.empty-materials,
.empty-steps {
  width: 100%;
  text-align: center;
  padding: 40rpx;
}

.steps-list {
  margin-top: 10rpx;
}

.step-item {
  display: flex;
  margin-bottom: 30rpx;
  position: relative;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-order {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  position: relative;
  z-index: 1;
}

.step-order text {
  font-size: 28rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.step-item::after {
  content: '';
  position: absolute;
  left: 29rpx;
  top: 60rpx;
  width: 2rpx;
  height: calc(100% - 60rpx);
  background: #EEEEEE;
}

.step-item:last-child::after {
  display: none;
}

.step-content {
  flex: 1;
}

.step-image {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  background: #F5F5F5;
}

.step-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  display: block;
}

.tips-box {
  background: linear-gradient(135deg, #FFEAA720 0%, #FFD93D20 100%);
  border-left: 6rpx solid #FFD93D;
  padding: 24rpx;
  border-radius: 0 16rpx 16rpx 0;
}

.tips-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.images-section {
  background: #FFFFFF;
  margin-top: 20rpx;
  padding: 30rpx;
}

.images-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.image-item {
  width: 31%;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  margin-right: 3.5%;
}

.image-item:nth-child(3n) {
  margin-right: 0;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.bar-actions {
  display: flex;
  margin-right: 30rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
}

.action-item:last-child {
  margin-right: 0;
}

.action-item.active .action-icon {
  color: #FF6B6B;
}

.action-icon {
  font-size: 44rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 20rpx;
  color: #999999;
}

.action-item.active .action-text {
  color: #FF6B6B;
}

.bar-btns {
  flex: 1;
  display: flex;
}

.btn-share,
.btn-edit {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50rpx;
}

.btn-share {
  background: linear-gradient(135deg, #4ECDC4 0%, #6EE7DE 100%);
  margin-right: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(78, 205, 196, 0.3);
}

.btn-edit {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.3);
}

.btn-share text,
.btn-edit text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: bold;
}
