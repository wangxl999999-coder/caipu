.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F5F5;
}

.sort-bar {
  display: flex;
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.sort-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666666;
  position: relative;
}

.sort-item.active {
  color: #FF6B6B;
  font-weight: bold;
}

.sort-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 50rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 3rpx;
}

.content {
  flex: 1;
  padding: 20rpx;
}

.recipe-list {
  padding-bottom: 30rpx;
}

.recipe-item {
  display: flex;
  overflow: hidden;
}

.recipe-image {
  width: 260rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  background: linear-gradient(135deg, #FFEAA7 0%, #FF6B6B 100%);
}

.recipe-image image {
  width: 100%;
  height: 100%;
}

.recipe-difficulty {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 12rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 20rpx;
}

.recipe-difficulty text {
  font-size: 20rpx;
  color: #FFFFFF;
}

.recipe-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.recipe-title {
  margin-bottom: 10rpx;
}

.recipe-title .title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
}

.recipe-category {
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.recipe-category text {
  font-size: 20rpx;
  color: #FFFFFF;
}

.recipe-desc {
  font-size: 24rpx;
  line-height: 1.5;
}

.recipe-footer {
  margin-top: 12rpx;
}

.recipe-author {
  flex-shrink: 0;
}

.author-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  background: #EEEEEE;
}

.author-name {
  font-size: 22rpx;
}

.recipe-stats {
  flex-shrink: 0;
}

.stat-item {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
}

.stat-item text:first-child {
  font-size: 20rpx;
  margin-right: 4rpx;
}

.stat-item text:last-child {
  font-size: 20rpx;
  color: #999999;
}

.empty-state {
  padding: 120rpx 40rpx;
}

.loading-state,
.no-more {
  padding: 40rpx;
  text-align: center;
}
